<?xml version="1.0" encoding="utf-8"?>
<!-- ==========================================================================
     AndroidManifest.xml — Sonic Unleashed Android (FUSÃO UNIFICADA)

     Fontes mescladas:
       • SonicPort_Fixed   → Vulkan required, VIBRATE, maxSdkVersion corretos,
                             configChanges completo, maxAspectRatio, minAspectRatio
       • port3             → sensorLandscape (rotação automática), OpenGL ES fallback
       • cleancode/pretest → estrutura base idêntica ao Fixed
     ========================================================================== -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.sega.sonicunleashed">

    <!-- ===================================================================
         Permissões
         Fixed: maxSdkVersion correto para evitar pedir em Android 13+
         =================================================================== -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ===================================================================
         Features requeridas
         Fixed: Vulkan 1.1 obrigatório (0x00401000 = VK_API_VERSION_1_1)
         port3: declara também OpenGL ES 3.0 como fallback futuro
         =================================================================== -->
    <uses-feature android:name="android.hardware.vulkan.version"
        android:version="0x00401000"
        android:required="true" />
    <uses-feature android:name="android.hardware.vulkan.compute"
        android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen"
        android:required="true" />
    <!-- OpenGL ES 3.0 declarado mas não obrigatório (Vulkan é o backend) -->
    <uses-feature android:glEsVersion="0x00030000"
        android:required="false" />

    <application
        android:label="Sonic Unleashed"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:resizeableActivity="true"
        android:extractNativeLibs="true">

        <activity
            android:name=".MainActivity"
            android:label="Sonic Unleashed"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:screenOrientation="sensorLandscape"
            android:exported="true"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen">

            <!-- Suporte a múltiplos aspect ratios: 16:9 → 20:9 → tablets -->
            <meta-data
                android:name="android.max_aspect"
                android:value="2.4" />
            <meta-data
                android:name="android.min_aspect"
                android:value="1.333" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
